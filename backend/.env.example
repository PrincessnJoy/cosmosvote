# CosmosVote Backend — Environment Variables
# Copy to .env and fill in values. Never commit .env.

# Sentry DSN for error tracking (leave blank to disable Sentry)
SENTRY_DSN=

# Application environment (development | staging | production)
NODE_ENV=development

# Application version reported to Sentry (e.g. git SHA or semver tag)
APP_VERSION=

# Stellar RPC endpoint to poll for contract events
STELLAR_RPC_URL=http://localhost:8000

# Contract IDs to monitor
GOVERNANCE_CONTRACT_ID=
TOKEN_CONTRACT_ID=

# Webhook URL to deliver events to (e.g. your notification handler)
WEBHOOK_URL=

# How often to poll for new events (milliseconds, default 6000)
POLL_INTERVAL_MS=6000
