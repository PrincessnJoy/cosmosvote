{
  "name": "cosmosvote-backend",
  "version": "1.0.0",
  "description": "CosmosVote off-chain notification and event-polling service",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@sentry/node": "8.54.0",
    "axios": "1.7.9"
  },
  "devDependencies": {
    "@types/jest": "29.5.14",
    "@types/node": "22.10.5",
    "jest": "29.7.0",
    "ts-jest": "29.2.5",
    "typescript": "5.7.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.ts"]
  }
}
