# CosmosVote Environment Configuration
# Copy this file to .env and fill in your values.
#
# ⚠️  WARNING: NEVER commit .env (or any file containing real secret keys) to
#     version control. This file (.env.example) contains only placeholder values
#     and is safe to commit. Your actual .env is listed in .gitignore.
#
#     For production deployments, use a secrets manager instead of storing
#     STELLAR_SECRET_KEY in a file. See docs/security/key-management.md.

# ─── Network ────────────────────────────────────────────────────────────────
# Options: local | testnet | mainnet
NETWORK=local

# ─── RPC Endpoints ──────────────────────────────────────────────────────────
STELLAR_RPC_URL=http://localhost:8000
# STELLAR_RPC_URL=https://soroban-testnet.stellar.org   # testnet
# STELLAR_RPC_URL=https://soroban-mainnet.stellar.org   # mainnet

# ─── Network Passphrase ─────────────────────────────────────────────────────
STELLAR_NETWORK_PASSPHRASE="Standalone Network ; February 2021"
# STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"   # testnet
# STELLAR_NETWORK_PASSPHRASE="Public Global Stellar Network ; September 2015"  # mainnet

# ─── Admin Keys ─────────────────────────────────────────────────────────────
# Secret key for the deploying admin account
STELLAR_SECRET_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Deployed Contract Addresses ────────────────────────────────────────────
# Populated after running deploy.sh
GOVERNANCE_CONTRACT_ID=
TOKEN_CONTRACT_ID=

# ─── Governance Parameters ──────────────────────────────────────────────────
# Minimum token balance required to create a proposal (0 = no minimum)
MIN_PROPOSAL_BALANCE=1000000

# Seconds between proposals per address (0 = no cooldown)
PROPOSAL_COOLDOWN=86400

# Whether admin cannot vote on proposals they created (true/false)
RESTRICT_ADMIN_VOTE=true

# ─── Token Parameters ───────────────────────────────────────────────────────
# Initial token supply minted to admin
INITIAL_TOKEN_SUPPLY=1000000000
