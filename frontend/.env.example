# CosmosVote Frontend environment
# Copy to .env.local and fill in your deployed contract IDs

# The network to connect to (e.g. testnet, mainnet)
VITE_NETWORK=testnet

# The Stellar contract ID for the Governance contract (starts with C, 56 characters)
VITE_GOVERNANCE_CONTRACT_ID=

# The Stellar contract ID for the Token contract (starts with C, 56 characters)
VITE_TOKEN_CONTRACT_ID=
